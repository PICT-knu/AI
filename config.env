# LLM 프로바이더 (groq / openrouter)
LLM_PROVIDER=openrouter

# Groq 모델 설정
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter 모델 설정
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# 공고 상세 분석(/jobs/detail-analysis) 전용 모델 (미설정 시 OPENROUTER_MODEL 사용)
JOB_ANALYSIS_MODEL=anthropic/claude-sonnet-4-5

# 타임아웃·세션
LLM_TIMEOUT_SECONDS=90
SESSION_TTL_SECONDS=3600
