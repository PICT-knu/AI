# LLM 프로바이더 (openrouter / groq)
LLM_PROVIDER=openrouter

# Groq 모델 설정 (보조 경로, LLM_PROVIDER=groq 일 때)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_LIGHT_MODEL=llama-3.1-8b-instant

# 검증 전용 모델: provider별 코드 기본값 사용
#   openrouter -> google/gemini-2.5-flash-lite, groq -> llama-3.1-8b-instant
# 강제로 고정하려면 VERIFY_MODEL 환경변수를 직접 지정.

# OpenRouter 모델 설정
OPENROUTER_MODEL=google/gemini-2.5-flash              # 생성/챗봇/일반 (품질 중요)
OPENROUTER_LIGHT_MODEL=google/gemini-2.5-flash-lite   # Planner 등 경량 단계
OPENROUTER_MATCHING_MODEL=deepseek/deepseek-chat      # 공고 매칭 (생성과 다른 모델)
PDF_EXTRACT_MODEL=google/gemini-2.5-flash-lite        # PDF 비전 추출

# 타임아웃·세션
LLM_TIMEOUT_SECONDS=90
SESSION_TTL_SECONDS=3600
