# Groq API 설정
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# LLM 프로바이더 설정: "groq" | "openrouter"
LLM_PROVIDER=groq

# OpenRouter 전환 시 사용 (LLM_PROVIDER=openrouter 일 때)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4

# 챗봇 세션 TTL (초)
SESSION_TTL_SECONDS=3600

# 검증 전용 모델 (생성 모델과 다른 아키텍처로 Self-Verification Bias 감소)
VERIFY_MODEL=gemma2-9b-it
