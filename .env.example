# Groq API 설정
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# LLM 프로바이더 설정: "groq" | "openrouter"
LLM_PROVIDER=groq

# OpenRouter 전환 시 사용 (LLM_PROVIDER=openrouter 일 때)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4

# 챗봇 세션 TTL (초)
SESSION_TTL_SECONDS=3600

# 검증 전용 모델 (LLM_PROVIDER에 따라 기본값이 다름)
# groq 사용 시 기본값: llama-3.1-8b-instant
# openrouter 사용 시 기본값: meta-llama/llama-3.1-8b-instruct
# VERIFY_MODEL=llama-3.1-8b-instant

# LLM 타임아웃 (초, 기본 90)
# LLM_TIMEOUT_SECONDS=90
